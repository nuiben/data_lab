# ── AWS ───────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default
# Or use explicit keys (not recommended; prefer profiles or IAM roles):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── S3 ────────────────────────────────────────────────────
DATA_LAB_S3_BUCKET=my-data-lab-bucket

# ── Snowflake ─────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=myaccount.us-east-1
SNOWFLAKE_USER=myuser
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=DATA_LAB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=SYSADMIN

# ── Local dev ─────────────────────────────────────────────
LOG_LEVEL=INFO
